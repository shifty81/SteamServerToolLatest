<Window x:Class="SteamServerTool.Dialogs.ServerInstallerWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🧙 Server Installer Wizard"
        Height="680" Width="820"
        MinHeight="600" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource DarkBgBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        FontFamily="Segoe UI" FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Step header -->
            <RowDefinition Height="*"/>      <!-- Step content -->
            <RowDefinition Height="Auto"/>   <!-- Nav buttons -->
        </Grid.RowDefinitions>

        <!-- ═══ STEP INDICATOR ═══ -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel>
                <TextBlock Text="🧙 Server Installer Wizard"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock x:Name="TxtStepDescription"
                           Text="Step 1 of 3 — Choose a Server Template"
                           FontSize="12"
                           Foreground="{StaticResource DimForegroundBrush}"
                           Margin="0,4,0,8"/>

                <!-- Step progress dots -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                    <Border x:Name="StepDot1" Width="100" Height="4" CornerRadius="2"
                            Background="{StaticResource AccentBrush}" Margin="0,0,4,0"/>
                    <Border x:Name="StepDot2" Width="100" Height="4" CornerRadius="2"
                            Background="{StaticResource ControlBgBrush}" Margin="0,0,4,0"/>
                    <Border x:Name="StepDot3" Width="100" Height="4" CornerRadius="2"
                            Background="{StaticResource ControlBgBrush}" Margin="0,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ STEP CONTENT AREA ═══ -->
        <Grid Grid.Row="1" Margin="24,16,24,8">

            <!-- ── STEP 1: Choose Template ── -->
            <Grid x:Name="Step1Panel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Select a server template to get started. Templates pre-fill common settings for popular games."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource DimForegroundBrush}"
                           Margin="0,0,0,12"/>

                <!-- Remote Server quick-add option -->
                <Border Grid.Row="1"
                        x:Name="RemoteServerBanner"
                        Background="#1A1A2A"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="14,10" Margin="0,0,0,12"
                        Cursor="Hand"
                        MouseLeftButtonUp="BtnAddRemoteInWizard_Click">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="🌐" FontSize="22"
                                   VerticalAlignment="Center" Margin="0,0,12,0"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Remote Server (RCON only)"
                                       FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="Already have a server running elsewhere? Add it by RCON host/port to monitor and send commands — no local install needed."
                                       TextWrapping="Wrap" FontSize="11"
                                       Foreground="{StaticResource DimForegroundBrush}"/>
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right" Text="→" FontSize="18"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </DockPanel>
                </Border>

                <!-- Template gallery -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="TemplateGallery" Orientation="Horizontal"/>
                </ScrollViewer>
            </Grid>

            <!-- ── STEP 2: Configure Server ── -->
            <ScrollViewer x:Name="Step2Panel" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Configure your server settings. You can adjust these later from the Config tab."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource DimForegroundBrush}"
                               Margin="0,0,0,16"/>

                    <!-- Template info banner -->
                    <Border x:Name="TemplateBanner"
                            Background="#1A2A3A"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="12,10" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtTemplateIcon" Text="🎮" FontSize="24"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtTemplateName" Text="Template Name"
                                           FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock x:Name="TxtTemplateDesc" Text="Template description"
                                           FontSize="11"
                                           Foreground="{StaticResource DimForegroundBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Config form grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Server Name -->
                        <Label Grid.Row="0" Grid.Column="0" Content="Server Name:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="4"
                                 x:Name="WizName" Tag="My Awesome Server"/>

                        <!-- Install Directory -->
                        <Label Grid.Row="2" Grid.Column="0" Content="Install To:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                                 x:Name="WizDir" Tag="e.g. C:\Servers\myserver"/>
                        <Button Grid.Row="2" Grid.Column="4"
                                Content="Browse…" Padding="10,6"
                                Click="BtnBrowseDir_Click"/>

                        <!-- Group -->
                        <Label Grid.Row="4" Grid.Column="0" Content="Group (optional):" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 x:Name="WizGroup" Tag="e.g. Survival Servers"/>

                        <!-- RCON Port -->
                        <Label Grid.Row="4" Grid.Column="3" Content="RCON Port:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="4"
                                 x:Name="WizRconPort"/>

                        <!-- Max Players -->
                        <Label Grid.Row="6" Grid.Column="0" Content="Max Players:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="6" Grid.Column="1"
                                 x:Name="WizMaxPlayers"/>

                        <!-- Query Port -->
                        <Label Grid.Row="6" Grid.Column="3" Content="Query Port:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="6" Grid.Column="4"
                                 x:Name="WizQueryPort"/>

                        <!-- Launch Args -->
                        <Label Grid.Row="8" Grid.Column="0" Content="Launch Args:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="4"
                                 x:Name="WizLaunchArgs" Tag="Additional launch arguments"/>

                        <!-- RCON Password -->
                        <Label Grid.Row="10" Grid.Column="0" Content="RCON Password:" VerticalAlignment="Center"/>
                        <Grid Grid.Row="10" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="WizRconPassword"
                                     Tag="Optional — leave blank to skip"
                                     Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="⚡ Generate"
                                    Padding="8,4" VerticalAlignment="Center"
                                    ToolTip="Generate a secure random RCON password"
                                    Click="BtnGenerateWizPassword_Click"/>
                        </Grid>
                    </Grid>

                    <!-- Auto-start checkbox -->
                    <CheckBox x:Name="WizAutoStart" Content="Auto-start this server when the tool launches"
                              Margin="0,16,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- ── STEP 3: Deploy ── -->
            <Grid x:Name="Step3Panel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status banner -->
                <Border Grid.Row="0" x:Name="DeployBanner"
                        Background="#1A2A1A"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="14,10" Margin="0,0,0,16">
                    <DockPanel>
                        <TextBlock x:Name="DeployBannerIcon" DockPanel.Dock="Left"
                                   Text="⏳" FontSize="20"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="DeployBannerTitle"
                                       Text="Ready to Deploy"
                                       FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock x:Name="DeployBannerSub"
                                       Text="Click 'Deploy' to begin installation."
                                       FontSize="11"
                                       Foreground="{StaticResource DimForegroundBrush}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Summary -->
                <Border Grid.Row="1"
                        Background="{StaticResource PanelBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Server:" FontSize="12"
                                   Foreground="{StaticResource DimForegroundBrush}"
                                   Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   x:Name="SumServer" Text="—"
                                   FontSize="12" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Template:" FontSize="12"
                                   Foreground="{StaticResource DimForegroundBrush}"
                                   Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   x:Name="SumTemplate" Text="—"
                                   FontSize="12"/>

                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="Directory:" FontSize="12"
                                   Foreground="{StaticResource DimForegroundBrush}"
                                   Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   x:Name="SumDir" Text="—"
                                   FontSize="12" TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <!-- Progress log -->
                <TextBox Grid.Row="2"
                         x:Name="TxtDeployLog"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11"
                         Background="#141414"
                         Foreground="#C8F08F"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1"/>

                <!-- Deploy / Finish buttons -->
                <DockPanel Grid.Row="3" Margin="0,12,0,0">
                    <Button x:Name="BtnDeploy"
                            DockPanel.Dock="Left"
                            Content="🚀 Deploy"
                            Padding="16,8"
                            Style="{StaticResource AccentButton}"
                            Click="BtnDeploy_Click"/>
                    <TextBlock x:Name="TxtDeployStatus"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"
                               Foreground="{StaticResource DimForegroundBrush}"
                               Text=""/>
                </DockPanel>
            </Grid>

        </Grid>

        <!-- ═══ NAVIGATION BUTTONS ═══ -->
        <Border Grid.Row="2"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        x:Name="BtnBack"
                        Content="← Back"
                        Padding="14,8"
                        Click="BtnBack_Click"
                        IsEnabled="False"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BtnCancel"
                            Content="Cancel"
                            Padding="14,8"
                            Margin="0,0,8,0"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="BtnNext"
                            Content="Next →"
                            Padding="14,8"
                            Style="{StaticResource AccentButton}"
                            Click="BtnNext_Click"/>
                    <Button x:Name="BtnFinish"
                            Content="✔ Finish"
                            Padding="14,8"
                            Style="{StaticResource AccentButton}"
                            Visibility="Collapsed"
                            IsEnabled="False"
                            Click="BtnFinish_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</Window>
