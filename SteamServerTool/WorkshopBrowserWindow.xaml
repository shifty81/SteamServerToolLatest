<Window x:Class="SteamServerTool.WorkshopBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Workshop Browser"
        Height="720" Width="740"
        MinHeight="500" MinWidth="560"
        Background="{StaticResource DarkBgBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- API Key row -->
            <RowDefinition Height="*"/>    <!-- Tab content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════
             ROW 0 — HEADER
             ══════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock DockPanel.Dock="Left"
                           Text="🔍 Steam Workshop Browser"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <TextBlock x:Name="TxtAppHeader"
                           Text="App ID: —"
                           Foreground="{StaticResource DimForegroundBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════
             ROW 1 — API KEY ROW
             ══════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Steam API Key:"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource DimForegroundBrush}"/>
                <Button DockPanel.Dock="Right" Content="Get free key ↗"
                        Margin="8,0,0,0" Padding="8,4"
                        Click="BtnGetApiKey_Click"/>
                <TextBox x:Name="TxtApiKey"
                         Tag="Optional — required for Search tab (not saved to disk)"
                         FontFamily="Consolas" FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════
             ROW 2 — TAB CONTENT
             ══════════════════════════════ -->
        <TabControl Grid.Row="2" x:Name="Tabs"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="10">

            <!-- ─── TAB: Search ─── -->
            <TabItem Header="🔍 Search">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Search bar -->
                        <RowDefinition Height="*"/>     <!-- Results -->
                        <RowDefinition Height="Auto"/>  <!-- Pagination / status -->
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right"
                                Content="🔍 Search"
                                Style="{StaticResource AccentButton}"
                                Padding="14,6" Margin="8,0,0,0"
                                Click="BtnSearch_Click"/>
                        <TextBox x:Name="TxtSearchQuery"
                                 Tag="Search for mods by name or keyword…"
                                 KeyDown="TxtSearchQuery_KeyDown"/>
                    </DockPanel>

                    <!-- Results list -->
                    <Border Grid.Row="1"
                            Background="{StaticResource PanelBgBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            ClipToBounds="True">
                        <ListBox x:Name="LbSearchResults"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,4,4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Top" Margin="0,3,0,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource DimForegroundBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="38" Margin="0,2,0,0"/>
                                            <WrapPanel Margin="0,3,0,0">
                                                <TextBlock Text="{Binding TagsLabel}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           Margin="0,0,8,0"/>
                                            </WrapPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding SubscriptionLabel}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource DimForegroundBrush}"
                                                       TextAlignment="Right"/>
                                            <TextBlock Text="{Binding UpdatedStr}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource DimForegroundBrush}"
                                                       TextAlignment="Right" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding IdStr}"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="{StaticResource DimForegroundBrush}"
                                                       TextAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Pagination / status -->
                    <DockPanel Grid.Row="2" Margin="0,8,0,0">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="BtnPrevPage" Content="◀ Prev"
                                    Padding="10,4" Margin="0,0,6,0"
                                    Click="BtnPrevPage_Click" IsEnabled="False"/>
                            <TextBlock x:Name="TxtPageInfo"
                                       Text="Page 1" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                       Foreground="{StaticResource DimForegroundBrush}"/>
                            <Button x:Name="BtnNextPage" Content="Next ▶"
                                    Padding="10,4"
                                    Click="BtnNextPage_Click" IsEnabled="False"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtSearchStatus"
                                   Text="Enter a search term and press Search."
                                   Foreground="{StaticResource DimForegroundBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ─── TAB: Collection ─── -->
            <TabItem Header="📦 Collection">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Collection ID input -->
                        <RowDefinition Height="*"/>     <!-- Results -->
                        <RowDefinition Height="Auto"/>  <!-- Status -->
                    </Grid.RowDefinitions>

                    <!-- Collection input -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right"
                                Content="📦 Browse Collection"
                                Style="{StaticResource AccentButton}"
                                Padding="14,6" Margin="8,0,0,0"
                                Click="BtnBrowseCollection_Click"/>
                        <TextBox x:Name="TxtCollectionId"
                                 Tag="Steam Workshop Collection ID or URL…"
                                 FontFamily="Consolas"
                                 KeyDown="TxtCollectionId_KeyDown"/>
                    </DockPanel>

                    <!-- Results list (reuses same template binding) -->
                    <Border Grid.Row="1"
                            Background="{StaticResource PanelBgBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            ClipToBounds="True">
                        <ListBox x:Name="LbCollectionResults"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,4,4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Top" Margin="0,3,0,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource DimForegroundBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="38" Margin="0,2,0,0"/>
                                            <WrapPanel Margin="0,3,0,0">
                                                <TextBlock Text="{Binding TagsLabel}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           Margin="0,0,8,0"/>
                                            </WrapPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding SubscriptionLabel}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource DimForegroundBrush}"
                                                       TextAlignment="Right"/>
                                            <TextBlock Text="{Binding UpdatedStr}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource DimForegroundBrush}"
                                                       TextAlignment="Right" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding IdStr}"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="{StaticResource DimForegroundBrush}"
                                                       TextAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Collection status -->
                    <TextBlock Grid.Row="2" x:Name="TxtCollectionStatus"
                               Text="Enter a Collection ID or paste a Workshop collection URL."
                               Foreground="{StaticResource DimForegroundBrush}"
                               Margin="0,8,0,0"/>
                </Grid>
            </TabItem>

            <!-- ─── TAB: Lookup by ID ─── -->
            <TabItem Header="🔑 Lookup by ID">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right"
                                Content="🔎 Lookup"
                                Style="{StaticResource AccentButton}"
                                Padding="14,6" Margin="8,0,0,0"
                                Click="BtnLookup_Click"/>
                        <TextBox x:Name="TxtLookupIds"
                                 Tag="One or more Workshop IDs, comma or newline separated…"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="60" VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"/>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Background="{StaticResource PanelBgBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            ClipToBounds="True">
                        <ListBox x:Name="LbLookupResults"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,4,4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  VerticalAlignment="Top" Margin="0,3,0,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource DimForegroundBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="38" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding SubscriptionLabel}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource DimForegroundBrush}"
                                                       TextAlignment="Right"/>
                                            <TextBlock Text="{Binding IdStr}"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="{StaticResource DimForegroundBrush}"
                                                       TextAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <TextBlock Grid.Row="2" x:Name="TxtLookupStatus"
                               Text="Paste Workshop mod IDs (no API key required)."
                               Foreground="{StaticResource DimForegroundBrush}"
                               Margin="0,8,0,0"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ══════════════════════════════
             ROW 3 — FOOTER
             ══════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="＋ Add Selected to Server"
                        Style="{StaticResource AccentButton}"
                        Padding="16,7" Margin="8,0,0,0"
                        Click="BtnAddSelected_Click"/>
                <Button DockPanel.Dock="Right"
                        Content="Cancel"
                        Padding="12,7"
                        Click="BtnCancel_Click"/>
                <TextBlock x:Name="TxtSelectionCount"
                           Text="No mods selected"
                           Foreground="{StaticResource DimForegroundBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
